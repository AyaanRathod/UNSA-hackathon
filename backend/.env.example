BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# watsonx core
WATSONX_API_KEY=your_api_key_here
WATSONX_PROJECT_ID=your_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL_ID=
# Vision model for transcript/screenshot OCR via watsonx Chat API (text-only instruct models cannot read images).
WATSONX_VISION_MODEL_ID=meta-llama/llama-3-2-11b-vision-instruct
WATSONX_API_VERSION=2024-05-31
WATSONX_VALIDATE_ON_STARTUP=false

# document understanding
# provider: local (default) or ibm
DOC_UNDERSTANDING_PROVIDER=local
IBM_DU_API_KEY=
IBM_DU_URL=

# optional Watson TTS
ENABLE_WATSON_TTS=false
WATSON_TTS_API_KEY=
WATSON_TTS_URL=
